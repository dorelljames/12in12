---
const steps = [
  {
    number: "01",
    title: "Place Your Bet",
    description:
      "Pick what you want to build and why. For profit, impact, or craft — set your thesis, your start date, and your deadline.",
    icon: "🎲",
  },
  {
    number: "02",
    title: "Build & Share",
    description:
      "Ship at your own pace. Share progress updates, milestones, and learnings along the way. The community follows your journey.",
    icon: "🏗️",
  },
  {
    number: "03",
    title: "Ship & Reflect",
    description:
      "Launch your bet and tell the story of what happened. Did it work? What did you learn? Your outcome helps the next builder.",
    icon: "🚀",
  },
];
---

<section class="relative py-20 sm:py-32 overflow-hidden" id="howitworks">
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-300/10 to-transparent"
  >
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:text-center">
      <h2 class="text-base font-semibold leading-7 text-primary-600">
        The Process
      </h2>
      <p
        class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl"
      >
        How it works
      </p>
      <p class="mt-6 text-lg leading-8 text-gray-600">
        A simple loop: bet, build, ship, reflect. At your own pace, with a
        community watching your back.
      </p>
    </div>

    <div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24">
      <div class="space-y-16">
        {
          steps.map((step) => (
            <div class="group relative flex flex-col lg:flex-row lg:items-center lg:gap-10">
              <div class="flex h-12 w-12 items-center justify-center rounded-full border border-primary-600/10 bg-primary-50 group-hover:bg-primary-100 transition-colors">
                <span class="text-2xl">{step.icon}</span>
              </div>

              <div class="mt-6 flex-auto lg:mt-0">
                <div class="flex items-center">
                  <span class="text-sm font-mono text-primary-600">
                    {step.number}
                  </span>
                  <div class="ml-3 h-px flex-auto bg-gradient-to-r from-primary-600/50 to-transparent" />
                </div>
                <h3 class="mt-2 text-xl font-semibold text-gray-900">
                  {step.title}
                </h3>
                <p class="mt-3 text-base leading-7 text-gray-600">
                  {step.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
