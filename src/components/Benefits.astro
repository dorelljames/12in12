---
const benefits = [
  {
    title: "Tell Your Story",
    description:
      "Every bet has a journey. Share your thesis, your progress, and your outcome — the community learns from your story.",
    icon: "📖",
  },
  {
    title: "Stay Accountable",
    description:
      "Public bets create real commitment. When others follow your journey, you show up and ship.",
    icon: "🎯",
  },
  {
    title: "Learn from Others",
    description:
      "See how other builders approach problems, choose tech stacks, and navigate the path from idea to launch.",
    icon: "💡",
  },
  {
    title: "Build Your Track Record",
    description:
      "Every bet you ship — for profit, impact, or craft — adds to your builder profile and proves you can execute.",
    icon: "📈",
  },
];
---

<section class="relative py-20 sm:py-32 bg-slate-900" id="benefits">
  <div class="absolute inset-0 bg-grid-slate-800/[0.1] bg-[size:40px_40px]">
  </div>
  <div class="absolute inset-0 bg-gradient-to-b from-slate-900 to-slate-900/80">
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:text-center">
      <h2 class="text-base font-semibold leading-7 text-primary-400">
        The Benefits
      </h2>
      <p class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">
        What you'll gain from joining
      </p>
      <p class="mt-6 text-lg leading-8 text-slate-300">
        Building is better with a community. Here's what you get when you
        bet on yourself alongside other builders.
      </p>
    </div>

    <div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-none">
      <div class="grid grid-cols-1 gap-x-8 gap-y-10 lg:grid-cols-4">
        {
          benefits.map((benefit) => (
            <div class="relative p-8 bg-slate-800/50 backdrop-blur-sm rounded-3xl border border-slate-700/50">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-600/10">
                <span class="text-xl">{benefit.icon}</span>
              </div>
              <h3 class="mt-6 text-lg font-semibold leading-8 text-white">
                {benefit.title}
              </h3>
              <p class="mt-2 text-base leading-7 text-slate-300">
                {benefit.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
