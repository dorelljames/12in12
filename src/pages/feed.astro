---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { supabase } from "../lib/supabase";

const { data: updates } = await supabase
  .from("product_updates")
  .select(`
    *,
    profiles:profile_id (
      username,
      full_name,
      avatar_url
    ),
    products:product_id (
      title,
      slug,
      status
    )
  `)
  .order("created_at", { ascending: false })
  .limit(50);

const getTypeConfig = (type: string) => {
  const configs: Record<string, { emoji: string; label: string; color: string; dotColor: string }> = {
    progress: { emoji: "📈", label: "Progress", color: "text-blue-400", dotColor: "bg-blue-500" },
    milestone: { emoji: "🏆", label: "Milestone", color: "text-amber-400", dotColor: "bg-amber-500" },
    launch: { emoji: "🚀", label: "Launch", color: "text-emerald-400", dotColor: "bg-emerald-500" },
    learning: { emoji: "💡", label: "Learning", color: "text-purple-400", dotColor: "bg-purple-500" },
  };
  return configs[type] || configs.progress;
};

const timeAgo = (date: string) => {
  const seconds = Math.floor((Date.now() - new Date(date).getTime()) / 1000);
  if (seconds < 60) return "just now";
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes}m ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  if (days < 30) return `${days}d ago`;
  return new Date(date).toLocaleDateString("en-US", { month: "short", day: "numeric" });
};

// Group updates by month/year
interface GroupedMonth {
  label: string;
  updates: typeof updates;
}

const groupedByMonth: GroupedMonth[] = [];
const monthMap = new Map<string, typeof updates>();

(updates || []).forEach((update) => {
  const date = new Date(update.created_at);
  const key = `${date.getFullYear()}-${String(date.getMonth()).padStart(2, "0")}`;
  const label = date.toLocaleDateString("en-US", { month: "long", year: "numeric" });

  if (!monthMap.has(key)) {
    monthMap.set(key, []);
    groupedByMonth.push({ label, updates: monthMap.get(key)! });
  }
  monthMap.get(key)!.push(update);
});

const title = "Community Feed - 12 in 12";
const description = "See what builders are shipping, learning, and launching in the 12 in 12 community.";
---

<Layout title={title}>
  <head slot="head">
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <link rel="canonical" href={new URL("/feed", Astro.url.origin).toString()} />
  </head>

  <div class="min-h-screen flex flex-col">
  <Navbar />

  <main class="flex-1 bg-gray-900 pt-24 pb-16">
    <div class="container mx-auto px-4 max-w-2xl">
      <div class="text-center mb-12">
        <h1 class="text-3xl font-bold text-white mb-2">Community Feed</h1>
        <p class="text-gray-400">See what builders are shipping, learning, and launching</p>
      </div>

      {groupedByMonth.length > 0 ? (
        <div class="space-y-10">
          {groupedByMonth.map((group) => (
            <div>
              {/* Month header */}
              <div class="flex items-center gap-3 mb-4">
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">{group.label}</h2>
                <div class="flex-1 h-px bg-gray-800"></div>
              </div>

              {/* Timeline entries for this month */}
              <div class="relative">
                {/* Vertical line */}
                <div class="absolute left-[19px] top-0 bottom-0 w-px bg-gray-800"></div>

                <div class="space-y-1">
                  {group.updates.map((update) => {
                    const typeConfig = getTypeConfig(update.type);
                    const day = new Date(update.created_at).getDate();
                    const profile = update.profiles;
                    const product = update.products;

                    return (
                      <div class="relative flex gap-4 py-3 group">
                        {/* Day + dot */}
                        <div class="flex items-start gap-2 shrink-0 w-10">
                          <span class="text-xs font-mono text-gray-500 w-5 text-right pt-0.5">{day}</span>
                          <div class={`w-2.5 h-2.5 rounded-full mt-1.5 ring-4 ring-gray-900 ${typeConfig.dotColor}`}></div>
                        </div>

                        {/* Content */}
                        <div class="flex-1 min-w-0 pb-3 border-b border-gray-800/50 group-last:border-0">
                          <div class="flex items-center gap-2 mb-1">
                            <a href={`/${profile?.username}`} class="flex items-center gap-2 shrink-0">
                              {profile?.avatar_url ? (
                                <img
                                  src={profile.avatar_url}
                                  alt={profile.full_name || profile.username}
                                  class="w-5 h-5 rounded-full"
                                />
                              ) : (
                                <div class="w-5 h-5 rounded-full bg-gray-700 flex items-center justify-center text-[10px] text-gray-400">
                                  {(profile?.username || "?")[0].toUpperCase()}
                                </div>
                              )}
                              <span class="text-sm font-medium text-gray-200 hover:text-emerald-400 transition-colors">
                                {profile?.full_name || profile?.username}
                              </span>
                            </a>
                            <span class={`text-xs ${typeConfig.color}`}>{typeConfig.emoji} {typeConfig.label}</span>
                            <span class="text-xs text-gray-600 ml-auto">{timeAgo(update.created_at)}</span>
                          </div>

                          {product && (
                            <a
                              href={`/projects/${product.slug}`}
                              class="text-xs text-gray-500 hover:text-gray-300 transition-colors mb-1 block"
                            >
                              on {product.title}
                            </a>
                          )}

                          <p class="text-sm text-gray-300 whitespace-pre-line leading-relaxed">{update.content}</p>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <div class="text-4xl mb-4">🌱</div>
          <p class="text-gray-400 text-lg">No updates yet. Be the first to share!</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
  </div>
</Layout>
