---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import Comments from "../../components/Comments.astro";
import { supabase } from "../../lib/supabase";

// Get project slug from URL params
const { slug } = Astro.params;

// Fetch project details with updates
const { data: project } = await supabase
  .from("products")
  .select(
    `
      *,
      profiles:profile_id (
        username,
        full_name,
        avatar_url,
        bio
      ),
      product_updates (
        id,
        type,
        content,
        created_at
      )
    `
  )
  .eq("slug", slug)
  .single();

// If project not found, redirect to 404
if (!project) {
  return Astro.redirect("/404");
}

// Sort updates newest first
const updates = (project.product_updates || []).sort(
  (a: any, b: any) =>
    new Date(b.created_at).getTime() - new Date(a.created_at).getTime()
);

// Get status config
const statusConfig: Record<
  string,
  { dotColor: string; textColor: string; bgColor: string; borderColor: string; label: string }
> = {
  completed: {
    dotColor: "bg-emerald-400",
    textColor: "text-emerald-400",
    bgColor: "bg-emerald-500/10",
    borderColor: "border-emerald-500/30",
    label: "Shipped",
  },
  in_progress: {
    dotColor: "bg-amber-400",
    textColor: "text-amber-400",
    bgColor: "bg-amber-500/10",
    borderColor: "border-amber-500/30",
    label: "In Progress",
  },
  not_started: {
    dotColor: "bg-slate-400",
    textColor: "text-slate-400",
    bgColor: "bg-slate-500/10",
    borderColor: "border-slate-500/30",
    label: "Not Started",
  },
};

const status = statusConfig[project.status] || statusConfig.not_started;

// Motivation config
const motivationConfig: Record<
  string,
  { label: string; color: string; bgColor: string; borderColor: string; icon: string }
> = {
  profit: {
    label: "For Profit",
    color: "text-green-400",
    bgColor: "bg-green-500/10",
    borderColor: "border-green-500/30",
    icon: "💰",
  },
  impact: {
    label: "For Impact",
    color: "text-blue-400",
    bgColor: "bg-blue-500/10",
    borderColor: "border-blue-500/30",
    icon: "🌍",
  },
  craft: {
    label: "For Craft",
    color: "text-amber-400",
    bgColor: "bg-amber-500/10",
    borderColor: "border-amber-500/30",
    icon: "🔨",
  },
};

const motivation = project.motivation
  ? motivationConfig[project.motivation]
  : null;

// Format date
const formatDate = (date: string) => {
  return new Date(date).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
};

// Format relative date for "time remaining"
const getTimeRemaining = (deadline: string) => {
  const now = new Date();
  const end = new Date(deadline);
  const diffMs = end.getTime() - now.getTime();
  const diffDays = Math.ceil(diffMs / (1000 * 60 * 60 * 24));

  if (diffDays < 0) return { text: `${Math.abs(diffDays)} days overdue`, overdue: true };
  if (diffDays === 0) return { text: "Due today", overdue: false };
  if (diffDays === 1) return { text: "1 day remaining", overdue: false };
  if (diffDays < 30) return { text: `${diffDays} days remaining`, overdue: false };
  const weeks = Math.floor(diffDays / 7);
  if (diffDays < 60) return { text: `${weeks} weeks remaining`, overdue: false };
  const months = Math.floor(diffDays / 30);
  return { text: `${months} months remaining`, overdue: false };
};

const timeRemaining = project.deadline ? getTimeRemaining(project.deadline) : null;

// Update type config
const updateTypeConfig: Record<
  string,
  { emoji: string; color: string; bgColor: string; borderColor: string; label: string }
> = {
  milestone: {
    emoji: "🏆",
    color: "text-purple-300",
    bgColor: "bg-purple-500/10",
    borderColor: "border-purple-500/30",
    label: "Milestone",
  },
  progress: {
    emoji: "📈",
    color: "text-blue-300",
    bgColor: "bg-blue-500/10",
    borderColor: "border-blue-500/30",
    label: "Progress",
  },
  launch: {
    emoji: "🚀",
    color: "text-emerald-300",
    bgColor: "bg-emerald-500/10",
    borderColor: "border-emerald-500/30",
    label: "Launch",
  },
  learning: {
    emoji: "💡",
    color: "text-amber-300",
    bgColor: "bg-amber-500/10",
    borderColor: "border-amber-500/30",
    label: "Learning",
  },
};

// Prepare SEO metadata
const title = `${project.title} - 12 in 12`;
const description = project.description
  ? `${project.description.slice(0, 155)}...`
  : `Check out ${project.title}, a bet by ${project.profiles.full_name || project.profiles.username} as part of the 12 in 12 challenge.`;

const ogImage =
  project.thumbnail_url || `${Astro.url.origin}/images/og-default.png`;

// Prepare JSON-LD structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: project.title,
  description: project.description,
  author: {
    "@type": "Person",
    name: project.profiles.full_name || project.profiles.username,
    url: `${Astro.url.origin}/${project.profiles.username}`,
  },
  datePublished: project.created_at,
  dateModified: project.updated_at || project.created_at,
  ...(project.completed_at && { dateCompleted: project.completed_at }),
  ...(project.tech_stack && {
    applicationCategory: project.tech_stack.join(", "),
  }),
  ...(project.demo_url && { url: project.demo_url }),
  ...(project.github_url && { codeRepository: project.github_url }),
  status: status.label,
};
---

<Layout title={title}>
  <head slot="head">
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <Navbar />

  <main class="bg-slate-900 pt-24 pb-16">
    <article class="mx-auto max-w-3xl px-4 sm:px-6">
      {/* Back Link */}
      <nav class="mt-4 mb-10">
        <a
          href="/bets"
          class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-300 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
            <path
              fill-rule="evenodd"
              d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
              clip-rule="evenodd"></path>
          </svg>
          Back to Bets
        </a>
      </nav>

      {/* ──────────────────────────────────────────── */}
      {/* SECTION 1: THE THESIS                        */}
      {/* ──────────────────────────────────────────── */}
      <header class="mb-10">
        {/* Motivation badge */}
        <div class="flex flex-wrap items-center gap-3 mb-5">
          {
            motivation && (
              <span
                class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium ${motivation.bgColor} ${motivation.color} border ${motivation.borderColor}`}
              >
                <span>{motivation.icon}</span>
                {motivation.label}
              </span>
            )
          }
          <span
            class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium ${status.bgColor} ${status.textColor} border ${status.borderColor}`}
          >
            <span class={`w-1.5 h-1.5 rounded-full ${status.dotColor}`}></span>
            {status.label}
          </span>
        </div>

        {/* Title */}
        <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight leading-tight mb-6">
          {project.title}
        </h1>

        {/* The thesis — the bet statement */}
        {
          project.description && (
            <blockquote class="border-l-2 border-primary-500/50 pl-5 text-lg text-slate-300 leading-relaxed">
              {project.description}
            </blockquote>
          )
        }

        {/* Thumbnail */}
        {
          project.thumbnail_url && (
            <div class="mt-8 rounded-lg overflow-hidden border border-slate-800">
              <img
                src={project.thumbnail_url}
                alt={project.title}
                class="w-full h-auto max-h-80 object-cover"
              />
            </div>
          )
        }

        {/* Builder byline */}
        <div class="mt-6 flex items-center gap-3">
          <a href={`/${project.profiles.username}`} class="flex-shrink-0">
            {
              project.profiles.avatar_url ? (
                <img
                  src={project.profiles.avatar_url}
                  alt={project.profiles.username}
                  class="w-9 h-9 rounded-full ring-1 ring-slate-700"
                />
              ) : (
                <div class="w-9 h-9 rounded-full bg-slate-700 flex items-center justify-center ring-1 ring-slate-600">
                  <span class="text-sm font-medium text-slate-300">
                    {project.profiles.username?.[0]?.toUpperCase()}
                  </span>
                </div>
              )
            }
          </a>
          <div class="text-sm">
            <a
              href={`/${project.profiles.username}`}
              class="font-medium text-slate-200 hover:text-white transition-colors"
            >
              {project.profiles.full_name || project.profiles.username}
            </a>
            <span class="text-slate-500 mx-1.5">&middot;</span>
            <time class="text-slate-500">
              {formatDate(project.started_at || project.created_at)}
            </time>
          </div>
        </div>
      </header>

      {/* ──────────────────────────────────────────── */}
      {/* SECTION 2: THE STAKES — ACCOUNTABILITY BAR   */}
      {/* ──────────────────────────────────────────── */}
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 py-4 mb-10 border-y border-slate-800 text-sm text-slate-400">
        {/* Started */}
        <div class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-slate-500" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
          </svg>
          <span>{formatDate(project.started_at || project.created_at)}</span>
        </div>

        {/* Deadline + time remaining */}
        {
          project.deadline && timeRemaining && (
            <div class={`flex items-center gap-1.5 ${timeRemaining.overdue ? "text-red-400" : ""}`}>
              <span class="text-slate-700">&middot;</span>
              <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
              </svg>
              <span>{timeRemaining.text}</span>
            </div>
          )
        }

        {/* Tech stack */}
        {
          project.tech_stack && project.tech_stack.length > 0 && (
            <>
              <span class="text-slate-700">&middot;</span>
              <div class="flex items-center gap-1.5">
                {project.tech_stack.map((tech: string) => (
                  <span class="text-xs text-slate-500">{tech}</span>
                ))}
              </div>
            </>
          )
        }

        {/* Links — inline with everything else */}
        {
          project.github_url && (
            <>
              <span class="text-slate-700">&middot;</span>
              <a
                href={project.github_url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-500 hover:text-slate-300 transition-colors"
                title="Source code"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                </svg>
              </a>
            </>
          )
        }
        {
          project.demo_url && (
            <>
              <span class="text-slate-700">&middot;</span>
              <a
                href={project.demo_url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs text-primary-400 hover:text-primary-300 transition-colors"
              >
                Live Demo ↗
              </a>
            </>
          )
        }
      </div>

      {/* ──────────────────────────────────────────── */}
      {/* SECTION 3: THE JOURNEY — TIMELINE            */}
      {/* ──────────────────────────────────────────── */}
      <section class="mb-16">
        <h2 class="text-lg font-semibold text-slate-300 mb-8">The Journey</h2>

        {
          updates.length > 0 ? (
            <div class="relative">
              {/* Timeline line */}
              <div class="absolute left-[15px] top-2 bottom-2 w-px bg-slate-800" />

              <div class="space-y-8">
                {updates.map((update: any) => {
                  const typeConf =
                    updateTypeConfig[update.type] || updateTypeConfig.progress;
                  return (
                    <div class="relative pl-10">
                      {/* Timeline dot */}
                      <div
                        class={`absolute left-0 top-1 w-[31px] h-[31px] rounded-full ${typeConf.bgColor} border ${typeConf.borderColor} flex items-center justify-center text-sm`}
                      >
                        {typeConf.emoji}
                      </div>

                      {/* Update content */}
                      <div>
                        <div class="flex items-center gap-3 mb-2">
                          <span
                            class={`text-xs font-medium uppercase tracking-wider ${typeConf.color}`}
                          >
                            {typeConf.label}
                          </span>
                          <time class="text-xs text-slate-600">
                            {formatDate(update.created_at)}
                          </time>
                        </div>
                        <div class="text-slate-300 leading-relaxed whitespace-pre-wrap">
                          {update.content}
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          ) : (
            <div class="py-12 text-center">
              <p class="text-slate-500 text-sm italic">
                This story is just getting started. Check back for updates.
              </p>
            </div>
          )
        }
      </section>

      {/* ──────────────────────────────────────────── */}
      {/* SECTION 4: THE OUTCOME — LESSONS LEARNED     */}
      {/* (only for completed bets, end of the story)  */}
      {/* ──────────────────────────────────────────── */}
      {
        project.status === "completed" && project.lessons_learned && (
          <section class="mb-16">
            <div class="rounded-lg border border-emerald-500/20 bg-emerald-500/5 p-6">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-emerald-400 text-lg">📝</span>
                <h2 class="text-base font-semibold text-emerald-300">
                  Lessons Learned
                </h2>
              </div>
              <div class="text-slate-300 leading-relaxed whitespace-pre-wrap">
                {project.lessons_learned}
              </div>
            </div>
          </section>
        )
      }

      {/* ──────────────────────────────────────────── */}
      {/* SECTION 5: THE COMMUNITY — COMMENTS          */}
      {/* ──────────────────────────────────────────── */}
      <section>
        <h2 class="text-lg font-semibold text-slate-300 mb-8">What do you think?</h2>
        <Comments productId={project.id} />
      </section>
    </article>
  </main>

  <Footer />
</Layout>
