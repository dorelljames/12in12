---
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabase";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ShareUpdateModal from "../components/ShareUpdateModal.astro";
import ProjectModal from "../components/ProjectModal.astro";

// Get username from URL params
const { username } = Astro.params;

// Get cookies
const accessToken = Astro.cookies.get("sb-access-token")?.value;
const refreshToken = Astro.cookies.get("sb-refresh-token")?.value;

// Set session if we have tokens
let user = null;
if (accessToken && refreshToken) {
  const {
    data: { user: sessionUser },
  } = await supabase.auth.setSession({
    access_token: accessToken,
    refresh_token: refreshToken,
  });
  user = sessionUser;
}

// Fetch user profile
const { data: profile, error: profileError } = await supabase
  .from("profiles")
  .select("*")
  .eq("username", username)
  .single();

// Redirect to signin if profile doesn't exist
if (!profile) {
  return Astro.redirect("/signin");
}

const isOwned = user && user.id === profile.user_id;

// Fetch products
const { data: products, error: productsError } = await supabase
  .from("products")
  .select("*")
  .eq("profile_id", profile?.id)
  .order("created_at", { ascending: false });

type ProductStatus = "completed" | "in_progress" | "not_started" | "canceled" | "parked";

interface Product {
  id?: string;
  title?: string;
  description?: string;
  month?: string;
  status?: ProductStatus;
  github_url?: string;
  demo_url?: string;
  tech_stack?: string[];
  lessons_learned?: string;
  thumbnail_url?: string;
  slug?: string;
  created_at?: string;
  started_at?: string;
  deadline?: string;
  motivation?: "profit" | "impact" | "craft";
}

const statusConfig: Record<string, { dotColor: string; textColor: string; bgColor: string; borderColor: string; label: string }> = {
  completed: { dotColor: "bg-emerald-400", textColor: "text-emerald-400", bgColor: "bg-emerald-500/10", borderColor: "border-emerald-500/30", label: "Shipped" },
  in_progress: { dotColor: "bg-amber-400", textColor: "text-amber-400", bgColor: "bg-amber-500/10", borderColor: "border-amber-500/30", label: "Building" },
  not_started: { dotColor: "bg-slate-400", textColor: "text-slate-400", bgColor: "bg-slate-500/10", borderColor: "border-slate-500/30", label: "Planned" },
  canceled: { dotColor: "bg-red-400", textColor: "text-red-400", bgColor: "bg-red-500/10", borderColor: "border-red-500/30", label: "Canceled" },
  parked: { dotColor: "bg-slate-400", textColor: "text-slate-400", bgColor: "bg-slate-500/10", borderColor: "border-slate-500/30", label: "Parked" },
};

const motivationConfig: Record<string, { label: string; color: string; bgColor: string; borderColor: string; icon: string }> = {
  profit: { label: "For Profit", color: "text-green-400", bgColor: "bg-green-500/10", borderColor: "border-green-500/30", icon: "💰" },
  impact: { label: "For Impact", color: "text-blue-400", bgColor: "bg-blue-500/10", borderColor: "border-blue-500/30", icon: "🌍" },
  craft: { label: "For Craft", color: "text-amber-400", bgColor: "bg-amber-500/10", borderColor: "border-amber-500/30", icon: "🔨" },
};

const updateTypeConfig: Record<string, { emoji: string; label: string; color: string }> = {
  progress: { emoji: "📈", label: "Progress", color: "text-blue-400" },
  milestone: { emoji: "🏆", label: "Milestone", color: "text-purple-400" },
  launch: { emoji: "🚀", label: "Launch", color: "text-emerald-400" },
  learning: { emoji: "💡", label: "Learning", color: "text-amber-400" },
};

const completedCount = (products || []).filter(
  (p: Product) => p.status === "completed"
).length;
const inProgressCount = (products || []).filter(
  (p: Product) => p.status === "in_progress"
).length;
const totalBets = (products || []).length;

// Current active bet
const activeBet = (products || []).find(
  (p: Product) => p.status === "in_progress"
);

const formatDate = (dateStr?: string) => {
  if (!dateStr) return null;
  const date = new Date(dateStr);
  return date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
};

const formatShortDate = (dateStr?: string) => {
  if (!dateStr) return null;
  const date = new Date(dateStr);
  return date.toLocaleDateString("en-US", { month: "short", day: "numeric" });
};

// Add new types
interface Update {
  id: string;
  content: string;
  type: "milestone" | "progress" | "launch" | "learning";
  created_at: string;
  product_id?: string;
  products?: {
    title: string;
    slug: string;
    month: string;
  };
}

// Add new query for updates
const { data: updates, error: updatesError } = await supabase
  .from("product_updates")
  .select(
    `
    *,
    products (
      title,
      slug,
      month
    )
  `
  )
  .eq("profile_id", profile?.id)
  .order("created_at", { ascending: false })
  .limit(10);

// Add new types
interface SocialLink {
  id: string;
  user_id: string;
  platform: "website" | "github" | "twitter" | "custom";
  url: string;
  title?: string;
  created_at: string;
  updated_at: string;
}

// Add new query for social links
const { data: socialLinks, error: socialLinksError } = await supabase
  .from("social_links")
  .select("*")
  .eq("user_id", profile?.user_id)
  .order("platform");

// Social link icons config
const socialIcons: Record<string, { label: string }> = {
  github: { label: "GitHub" },
  twitter: { label: "Twitter" },
  website: { label: "Website" },
  custom: { label: "Link" },
};

// Prepare SEO metadata
const title = `${profile?.full_name || username}'s Bets - 12 in 12`;
const description = profile?.bio
  ? `${profile.bio} • ${completedCount} bets shipped, ${inProgressCount} in progress.`
  : `Follow ${profile?.full_name || username}'s journey betting on themselves. ${totalBets} bets placed, ${completedCount} shipped, ${inProgressCount} in progress.`;

// Prepare JSON-LD structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: title,
  description: description,
  url: Astro.url,
  mainEntity: {
    "@type": "Person",
    name: profile?.full_name || username,
    alternateName: username,
    description: profile?.bio,
    image: profile?.avatar_url,
    url: Astro.url,
    ...(socialLinks?.length && {
      sameAs: socialLinks.map((link) => link.url),
    }),
    memberOf: {
      "@type": "Organization",
      name: "12 in 12",
      description: "Community of builders betting on themselves, one build at a time",
    },
    makesOffer: products?.map((product) => ({
      "@type": "SoftwareApplication",
      name: product.title,
      description: product.description,
      applicationCategory: product.tech_stack?.join(", "),
      ...(product.demo_url && { url: product.demo_url }),
      ...(product.github_url && { codeRepository: product.github_url }),
    })),
  },
};
---

<Layout title={title}>
  <head slot="head">
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={profile?.avatar_url ||
        `${Astro.url.origin}/images/og-profile.png`}
    />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta
      property="twitter:image"
      content={profile?.avatar_url ||
        `${Astro.url.origin}/images/og-profile.png`}
    />
    <link
      rel="canonical"
      href={new URL(`/${username}`, Astro.url.origin).toString()}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <div class="min-h-screen flex flex-col">
    <Navbar />
    {
      isOwned && (
        <ShareUpdateModal profileId={profile.id} products={products || []} />
      )
    }
    {isOwned && <ProjectModal profileId={profile.id} />}

    <main class="flex-1 bg-slate-900">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 pt-28 pb-16">

        {/* ──────────────────────────────────────────── */}
        {/* HEADER — The Builder                         */}
        {/* ──────────────────────────────────────────── */}
        <header class="mb-12">
          <div class="flex items-start gap-5">
            {/* Avatar */}
            {
              profile?.avatar_url ? (
                <img
                  src={profile.avatar_url}
                  alt={username}
                  class="w-16 h-16 rounded-full ring-2 ring-slate-700 flex-shrink-0"
                />
              ) : (
                <div class="w-16 h-16 rounded-full bg-slate-800 flex items-center justify-center ring-2 ring-slate-700 flex-shrink-0">
                  <span class="text-xl font-medium text-slate-300">
                    {(username as string)?.[0]?.toUpperCase()}
                  </span>
                </div>
              )
            }

            <div class="min-w-0">
              {/* Name + edit link */}
              <div class="flex items-center gap-3">
                <h1 class="text-2xl font-bold text-white truncate">
                  {profile?.full_name || username}
                </h1>
                {
                  isOwned && (
                    <a
                      href="/profile"
                      class="text-slate-500 hover:text-slate-300 transition-colors flex-shrink-0"
                      title="Edit profile"
                    >
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                      </svg>
                    </a>
                  )
                }
              </div>

              {/* Bio */}
              <p class="mt-1 text-slate-400 text-sm leading-relaxed">
                {profile?.bio || "Betting on themselves, one build at a time."}
              </p>

              {/* Social links */}
              {
                socialLinks && socialLinks.length > 0 && (
                  <div class="flex flex-wrap items-center gap-3 mt-3">
                    {socialLinks.map((link: SocialLink) => (
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs text-slate-500 hover:text-slate-300 transition-colors"
                      >
                        {socialIcons[link.platform]?.label || link.title || "Link"}
                      </a>
                    ))}
                  </div>
                )
              }
            </div>
          </div>

          {/* Quick stats + current focus — single line */}
          <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-slate-500">
            <span>{totalBets} bets</span>
            <span class="text-emerald-400">{completedCount} shipped</span>
            {
              inProgressCount > 0 && (
                <span class="text-amber-400">{inProgressCount} building</span>
              )
            }
            {
              activeBet && (
                <>
                  <span class="text-slate-700">|</span>
                  <span class="text-slate-400">
                    Currently: <a href={`/projects/${activeBet.slug}`} class="text-white hover:text-primary-400 transition-colors font-medium">{activeBet.title}</a>
                  </span>
                </>
              )
            }
          </div>
        </header>

        {/* ──────────────────────────────────────────── */}
        {/* THE STORY SO FAR — Updates Timeline          */}
        {/* ──────────────────────────────────────────── */}
        <section class="mb-16">
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-lg font-semibold text-slate-300">The Story So Far</h2>
            {
              isOwned && (
                <button
                  id="shareUpdateButton"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-emerald-400 bg-emerald-500/10 rounded-full border border-emerald-500/30 hover:bg-emerald-500/20 transition-colors"
                >
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                  </svg>
                  Share Update
                </button>
              )
            }
          </div>

          {
            updates && updates.length > 0 ? (
              <div class="relative">
                {/* Timeline line */}
                <div class="absolute left-[15px] top-2 bottom-2 w-px bg-slate-800" />

                <div class="space-y-6">
                  {updates.map((update: Update) => {
                    const typeConf = updateTypeConfig[update.type] || updateTypeConfig.progress;
                    return (
                      <div class="relative pl-10 group">
                        {/* Timeline dot */}
                        <div class="absolute left-[7px] top-1 w-[17px] h-[17px] rounded-full bg-slate-900 border-2 border-slate-700 flex items-center justify-center text-[10px]">
                          {typeConf.emoji}
                        </div>

                        {/* Content */}
                        <div>
                          <div class="flex flex-wrap items-center gap-2 mb-1.5">
                            <span class={`text-xs font-medium uppercase tracking-wider ${typeConf.color}`}>
                              {typeConf.label}
                            </span>
                            {update.product_id && update.products && (
                              <>
                                <span class="text-slate-700">&middot;</span>
                                <a
                                  href={`/projects/${update.products.slug}`}
                                  class="text-xs text-slate-500 hover:text-slate-300 transition-colors"
                                >
                                  {update.products.title}
                                </a>
                              </>
                            )}
                            <time class="text-xs text-slate-600 ml-auto">
                              {formatShortDate(update.created_at)}
                            </time>
                            {isOwned && (
                              <button
                                type="button"
                                class="text-slate-700 hover:text-slate-400 opacity-0 group-hover:opacity-100 transition-opacity"
                                onclick={`window.showEditModal(${JSON.stringify({
                                  id: update.id,
                                  type: update.type,
                                  content: update.content,
                                  product_id: update.product_id,
                                })})`}
                              >
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                                </svg>
                              </button>
                            )}
                          </div>
                          <p class="text-sm text-slate-300 whitespace-pre-line leading-relaxed">
                            {update.content}
                          </p>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            ) : (
              <div class="py-12 text-center">
                <p class="text-slate-500 text-sm italic">
                  {isOwned
                    ? "Your story starts with an update. What are you working on?"
                    : `${profile?.full_name || username} hasn't shared any updates yet.`}
                </p>
                {isOwned && (
                  <button
                    id="shareUpdateButton2"
                    class="mt-4 inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-emerald-400 bg-emerald-500/10 rounded-full border border-emerald-500/30 hover:bg-emerald-500/20 transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                    </svg>
                    Share Your First Update
                  </button>
                )}
              </div>
            )
          }

          {/* Load More */}
          {
            (updates?.length ?? 0) >= 10 && (
              <div class="text-center mt-8">
                <button class="text-xs text-slate-500 hover:text-slate-300 transition-colors">
                  Load more updates
                </button>
              </div>
            )
          }
        </section>

        {/* ──────────────────────────────────────────── */}
        {/* ALL BETS — Editorial List                    */}
        {/* ──────────────────────────────────────────── */}
        <section>
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-lg font-semibold text-slate-300">All Bets</h2>
            {
              isOwned && (
                <button
                  type="button"
                  id="newBetButton"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-emerald-400 bg-emerald-500/10 rounded-full border border-emerald-500/30 hover:bg-emerald-500/20 transition-colors"
                >
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                  </svg>
                  New Bet
                </button>
              )
            }
          </div>

          {
            products && products.length > 0 ? (
              <div class="space-y-4">
                {products.map((product: Product) => {
                  const st = statusConfig[product.status || "not_started"] || statusConfig.not_started;
                  const mot = product.motivation ? motivationConfig[product.motivation] : null;

                  return (
                    <div class="group relative rounded-lg border border-slate-800 bg-slate-800/30 hover:border-slate-700 transition-colors overflow-hidden">
                      {/* Cover image */}
                      {product.thumbnail_url && (
                        <a href={product.slug ? `/projects/${product.slug}` : undefined} class="block">
                          <div class="relative h-40 bg-slate-800">
                            <img
                              src={product.thumbnail_url}
                              alt={product.title}
                              class="w-full h-full object-cover"
                              loading="lazy"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent" />
                          </div>
                        </a>
                      )}

                      <div class="p-5">
                      {/* Owner edit button */}
                      {isOwned && (
                        <button
                          type="button"
                          class="absolute top-4 right-4 z-10 text-slate-400 hover:text-white bg-slate-900/60 backdrop-blur-sm rounded-full p-1.5 opacity-0 group-hover:opacity-100 transition-opacity"
                          title="Edit Bet"
                          data-project={JSON.stringify({
                            ...product,
                            started_at: product.started_at,
                            deadline: product.deadline,
                            motivation: product.motivation,
                          })}
                        >
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                          </svg>
                        </button>
                      )}

                      {/* Badges row */}
                      <div class="flex flex-wrap items-center gap-2 mb-3">
                        {mot && (
                          <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium ${mot.bgColor} ${mot.color} border ${mot.borderColor}`}>
                            <span>{mot.icon}</span>
                            {mot.label}
                          </span>
                        )}
                        <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium ${st.bgColor} ${st.textColor} border ${st.borderColor}`}>
                          <span class={`w-1.5 h-1.5 rounded-full ${st.dotColor}`} />
                          {st.label}
                        </span>
                        {product.started_at && (
                          <span class="text-xs text-slate-600 ml-auto">
                            {formatDate(product.started_at)}
                          </span>
                        )}
                      </div>

                      {/* Title */}
                      <h3 class="text-lg font-semibold text-white mb-1.5">
                        {product.slug ? (
                          <a href={`/projects/${product.slug}`} class="hover:text-primary-400 transition-colors">
                            {product.title}
                          </a>
                        ) : (
                          product.title
                        )}
                      </h3>

                      {/* Description / thesis */}
                      {product.description && (
                        <p class="text-sm text-slate-400 leading-relaxed line-clamp-2 mb-3">
                          {product.description}
                        </p>
                      )}

                      {/* Footer: tech stack + links */}
                      <div class="flex flex-wrap items-center gap-3">
                        {product.tech_stack && product.tech_stack.length > 0 && (
                          <div class="flex items-center gap-1.5">
                            {product.tech_stack.map((tech: string) => (
                              <span class="px-1.5 py-0.5 text-[10px] font-medium text-slate-500 bg-slate-800 rounded border border-slate-700">
                                {tech}
                              </span>
                            ))}
                          </div>
                        )}

                        <div class="flex items-center gap-3 ml-auto">
                          {product.github_url && (
                            <a
                              href={product.github_url}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="text-slate-600 hover:text-slate-300 transition-colors"
                              title="Source code"
                              onclick="event.stopPropagation()"
                            >
                              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                              </svg>
                            </a>
                          )}
                          {product.demo_url && (
                            <a
                              href={product.demo_url}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="inline-flex items-center gap-1 text-xs text-primary-400 hover:text-primary-300 transition-colors"
                              onclick="event.stopPropagation()"
                            >
                              <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                                <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
                                <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
                              </svg>
                              Demo
                            </a>
                          )}
                          {product.slug && (
                            <a
                              href={`/projects/${product.slug}`}
                              class="text-xs text-slate-500 hover:text-slate-300 transition-colors"
                              onclick="event.stopPropagation()"
                            >
                              Read more →
                            </a>
                          )}
                        </div>
                      </div>

                      {/* Lessons learned for completed bets */}
                      {product.status === "completed" && product.lessons_learned && (
                        <div class="mt-3 pt-3 border-t border-slate-800">
                          <p class="text-xs text-slate-500 italic line-clamp-2">
                            📝 "{product.lessons_learned}"
                          </p>
                        </div>
                      )}
                      </div>{/* close p-5 wrapper */}
                    </div>
                  );
                })}
              </div>
            ) : (
              <div class="py-12 text-center">
                <p class="text-slate-500 text-sm italic">
                  {isOwned
                    ? "Ready to bet on yourself? Place your first bet."
                    : `${profile?.full_name || username} hasn't placed any bets yet.`}
                </p>
                {isOwned && (
                  <button
                    type="button"
                    id="firstBetButton"
                    class="mt-4 inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-emerald-400 bg-emerald-500/10 rounded-full border border-emerald-500/30 hover:bg-emerald-500/20 transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                    </svg>
                    Place Your First Bet
                  </button>
                )}
              </div>
            )
          }
        </section>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<script>
  // Initialize modal functionality
  document.addEventListener("DOMContentLoaded", () => {
    const shareButton = document.getElementById("shareUpdateButton");
    const shareButton2 = document.getElementById("shareUpdateButton2");
    const modal = document.getElementById("shareUpdateModal");

    if (shareButton && modal) {
      shareButton.addEventListener("click", () => {
        modal.classList.remove("hidden");
      });
    }

    if (shareButton2 && modal) {
      shareButton2.addEventListener("click", () => {
        modal.classList.remove("hidden");
      });
    }

    // New Bet button opens project modal with empty data
    const newBetButton = document.getElementById("newBetButton");
    if (newBetButton) {
      newBetButton.addEventListener("click", () => {
        // @ts-ignore
        window.showProjectModal?.({});
      });
    }

    // First Bet CTA button opens project modal with empty data
    const firstBetButton = document.getElementById("firstBetButton");
    if (firstBetButton) {
      firstBetButton.addEventListener("click", () => {
        // @ts-ignore
        window.showProjectModal?.({});
      });
    }

    // Add click handlers for project edit buttons
    document.querySelectorAll("button[data-project]").forEach((button) => {
      button.addEventListener("click", (e) => {
        e.stopPropagation();
        const target = e.currentTarget as HTMLButtonElement;
        const projectData = JSON.parse(target.dataset.project || "{}");
        // @ts-ignore
        window.showProjectModal?.(projectData);
      });
    });
  });
</script>
